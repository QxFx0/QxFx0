executable qxfx0-main
  import:        warnings, base-deps
  autogen-modules:
    Paths_qxfx0
  main-is:       Main.hs
  other-modules:
    Paths_qxfx0
    CLI
    CLI.Health
    CLI.Http
    CLI.Protocol
    CLI.State
    CLI.Turn
    CLI.Worker
  hs-source-dirs: app
  build-depends: qxfx0, directory >=1.3 && <1.4, filepath >=1.4 && <1.5, process >=1.6 && <1.7, time >=1.11 && <1.13, unix >=2.7 && <2.9

test-suite qxfx0-test
  import:        warnings, base-deps
  type:          exitcode-stdio-1.0
  main-is:       TestMain.hs
  other-modules:
    Test.Support
    Test.Suite.CoreBehavior
    Test.Suite.TurnPipelineProtocol
    Test.Suite.RuntimeInfrastructure
    Test.Suite.HttpRuntime
    Test.Suite.SemanticCorpus
    Test.Suite.LexiconTests
  hs-source-dirs: test
  build-tool-depends:
    qxfx0:qxfx0-main
  build-depends:
    , qxfx0
    , HUnit        >=1.6 && <1.7
    , QuickCheck   >=2.14 && <2.15
    , hspec         >=2.7 && <2.12
    , vector        >=0.12 && <0.14
    , async         >=2.2 && <2.3
    , directory     >=1.3 && <1.4
    , filepath      >=1.4 && <1.5
    , time          >=1.11 && <1.13
