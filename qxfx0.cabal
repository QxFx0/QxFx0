cabal-version: 3.4
name:          qxfx0
version:       0.1.0.0
synopsis:      QxFx0 Flagship Philosophical Dialogue Thinking System
description:   A synthesis of five experiments combining Agda, Nix, SQL, and Haskell
               for a Russian-language philosophical dialogue thinking system with
               14 CanonicalMoveFamily types, R5 verdict routing, evidence graphs,
               consciousness kernel, Bayesian intuition, and meaning graph with
               dream rewiring.
category:      AI
author:        QxFx Research
maintainer:    QxFx Research <qxfx@research.example>
license:       MIT
data-files:
  migrations/*.sql
  resources/lexicon/*.json
  resources/morphology/*.json
  semantics/*.nix
  spec/*.agda
  spec/*.tsv
  spec/datalog/*.dl
  spec/gf/*.gf
  spec/gf/*.tsv
  spec/sql/*.sql
  spec/sql/lexicon/*.sql
  scripts/http_runtime.py

common warnings
  ghc-options: -Wall -Wcompat -Wincomplete-uni-patterns
               -Wincomplete-record-updates -Wredundant-constraints
               -Wmissing-deriving-strategies -Wno-unticked-promoted-constructors

common base-deps
  build-depends:
    , base          >=4.17 && <5
    , text          >=1.2 && <2.2
    , bytestring    >=0.11 && <0.13
    , mtl           >=2.2 && <2.4
    , containers    >=0.6 && <0.8
    , aeson         >=1.5 && <2.3
    , unordered-containers >=0.2 && <0.3

